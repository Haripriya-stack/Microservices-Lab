@model Mango.Web.Models.CouponDTO

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>CouponDTO</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="CreateCouponDefaultView">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
          
